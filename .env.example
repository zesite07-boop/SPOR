# ==========================================================
# SEREY PADMA - ENVIRONMENT VARIABLES (EXAMPLE ONLY)
# Ne jamais committer de vraies clés dans le dépôt.
# ==========================================================

# URL publique canonique de l'app (metadata, sitemap, robots, SEO)
# Production Vercel: https://ton-projet.vercel.app ou https://ton-domaine.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optionnel : masquer le badge "Mode demo · local" en production
# true = badge visible, false = badge masqué
NEXT_PUBLIC_SHOW_DEMO_BADGE=true

# ----------------------------------------------------------
# Supabase (optionnel)
# Sans ces variables, l'app fonctionne en mode local Dexie/PWA.
# ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# À ajouter dans Supabase Dashboard → Authentication → URL configuration :
# - Site URL : https://ton-domaine.tld
# - Redirect URLs : https://ton-domaine.tld/auth/callback , http://localhost:3000/auth/callback

# ----------------------------------------------------------
# Stripe (optionnel)
# Requis pour activer le checkout en ligne.
# ----------------------------------------------------------
# Clé secrète serveur uniquement (jamais en NEXT_PUBLIC_*)
STRIPE_SECRET_KEY=sk_test_...

# Optionnel recommandé si webhook Stripe ajouté plus tard
# STRIPE_WEBHOOK_SECRET=whsec_...
